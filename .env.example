# 环境变量模板
# 复制本文件为 .env 并填入实际值
# ⚠️ .env 文件不得提交到 Git，已配置在 .gitignore 中

# ─────────────────────────────────────────────
# 深证信官方 API 配置（experiment/cninfo-official-api 分支）
# ─────────────────────────────────────────────
# 仅在 crawl 阶段使用 --crawl-backend official 时需要。
# CNINFO_ACCESS_KEY=your_cninfo_access_key_here
# CNINFO_ACCESS_SECRET=your_cninfo_access_secret_here

# ─────────────────────────────────────────────
# LLM API 配置（字段抽取、文本评估）
# ─────────────────────────────────────────────
# 请任选一种 Provider，取消对应选项的注释并填入真实 Key。
# 代码默认通过 LLM_BASE_URL / LLM_API_KEY / LLM_MODEL 三个变量读取。
# 如果使用本机已登录的 Kimi Code CLI，可设置 LLM_BACKEND=kimi_code_cli。

# --- 选项 A：Kimi Code CLI（推荐给本项目本机跑批）---
# LLM_BACKEND=kimi_code_cli
# KIMI_CODE_CLI_COMMAND=kimi
# KIMI_CODE_CLI_MODEL=

# --- 选项 B：Kimi Code API（仅适用于官方支持的 coding agent）---
# LLM_BACKEND=http
# LLM_BASE_URL=https://api.kimi.com/coding/v1
# LLM_API_KEY=your_kimi_code_api_key_here
# LLM_MODEL=kimi-for-coding

# --- 选项 C：硅基流动（课程讲义推荐）---
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=your_siliconflow_api_key_here
# LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# --- 选项 D：DeepSeek ---
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=your_deepseek_api_key_here
# LLM_MODEL=deepseek-chat

# --- 选项 E：OpenAI / 兼容接口 ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4o-mini

# --- 选项 F：智谱 AI ---
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_API_KEY=your_zhipu_api_key_here
# LLM_MODEL=glm-4-flash

# ─────────────────────────────────────────────
# MinerU API 配置（PDF 解析）
# ─────────────────────────────────────────────
# CLI 默认 backend 仍为 local；当前项目复跑/补跑年报 parse 推荐 api-batch。
# MinerU 精准 API 分段 smoke / batch smoke：
#   uv run python src/main.py --stage parse --parse-backend api --limit 1
#   uv run python src/main.py --stage parse --parse-backend api-batch --limit 2
# 取消下行注释并填入真实 Token；不要把真实 Token 提交到 Git。
# MINERU_API_KEY=your_mineru_api_key_here
# 精准解析 API 创建任务端点；通常无需修改。
# MINERU_API_URL=https://mineru.net/api/v4/extract/task
# URL 批量解析默认每批 50 个 page segment，贴近官方 50 files/min 提交限流。
# MINERU_API_BATCH_SIZE=50
# MINERU_API_BATCH_URL=https://mineru.net/api/v4/extract/task/batch
# MINERU_API_BATCH_QUERY_URL=https://mineru.net/api/v4/extract-results/batch/{batch_id}
# 本地结果包下载/解压并发度；API 侧解析已批量并行，本地不再逐个串行收尾。
# MINERU_API_DOWNLOAD_WORKERS=8
# MINERU_API_EXTRACT_WORKERS=4
# MinerU 结果 zip 下载重试；VPN/网络抖动导致 SSL EOF 时会自动补救。
# MINERU_API_DOWNLOAD_RETRIES=3
# MINERU_API_DOWNLOAD_RETRY_DELAY=2.0

# ─────────────────────────────────────────────
# MinerU 本地运行配置（无需 API Key）
# ─────────────────────────────────────────────
# 国内网络建议设置：
# MINERU_MODEL_SOURCE=modelscope
# 强制使用 CUDA：
# MINERU_DEVICE_MODE=cuda
# 高精度后端（解析更慢但更准）：
# MINERU_BACKEND=hybrid-auto-engine
